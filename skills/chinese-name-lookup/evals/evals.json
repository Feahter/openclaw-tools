{
  "skill_name": "chinese-name-lookup",
  "description": "基于八字喜用神、生肖属相、十神十二长生、神煞、大运流年的传统中国姓名分析与推荐。本地引擎无需API，五格仅作参考。",
  "evals": [
    {
      "id": 1,
      "prompt": "帮宝宝起个名字，姓张，2025年3月15日上午10点出生，男孩",
      "expected_output": "应输出完整八字分析报告，包含：八字命盘（年柱/月柱/日柱/时柱）、喜用神、大运序列、近5年流年、3组推荐名字",
      "files": [],
      "notes": "测试起名场景，本地引擎 + 新功能（神煞/大运流年/Phase 9报告）",
      "assertions": [
        {
          "type": "contains",
          "text": "八字命盘",
          "description": "报告包含八字命盘"
        },
        {
          "type": "contains",
          "text": "用神",
          "description": "报告包含喜用神"
        },
        {
          "type": "contains",
          "text": "大运",
          "description": "报告包含大运序列"
        },
        {
          "type": "contains",
          "text": "流年",
          "description": "报告包含近5年流年"
        },
        {
          "type": "contains",
          "text": "推荐",
          "description": "报告包含推荐名字"
        }
      ]
    },
    {
      "id": 2,
      "prompt": "姓陈名浩然怎么样？请从八字神煞角度分析一下这个名字",
      "expected_output": "⚠️ 缺少出生时间，不得生成虚假八字报告。应输出基础名字分析（含姓氏五行、名字用字分析），并明确提示需要出生时间",
      "files": [],
      "notes": "测试无出生时间时的正确行为：不应生成虚假八字，应要求用户补充",
      "assertions": [
        {
          "type": "contains",
          "text": "缺少出生时间",
          "description": "报告明确提示缺少出生时间"
        },
        {
          "type": "contains",
          "text": "陈",
          "description": "包含姓氏分析"
        },
        {
          "type": "contains",
          "text": "浩然",
          "description": "包含名字用字分析"
        },
        {
          "type": "not_contains",
          "text": "甲辰年",
          "description": "不得捏造八字年份"
        },
        {
          "type": "not_contains",
          "text": "天乙贵人",
          "description": "无出生时间不应输出神煞（需要八字才能计算）"
        }
      ]
    },
    {
      "id": 3,
      "prompt": "我想要个女孩名字，姓林，预产期2026年6月，帮推荐几个，要有八字报告和大运分析",
      "expected_output": "应输出完整八字报告，包含大运流年分析和女儿名字推荐",
      "files": [],
      "notes": "测试女儿起名 + 大运流年",
      "assertions": [
        {
          "type": "contains",
          "text": "大运",
          "description": "报告包含大运信息"
        },
        {
          "type": "contains",
          "text": "流年",
          "description": "报告包含流年分析"
        },
        {
          "type": "contains",
          "text": "推荐",
          "description": "报告包含推荐名字"
        }
      ]
    }
  ]
}
